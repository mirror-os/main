# Mirror OS default Flatpak apps — installed system-scope by the image.
# This list is the runtime source of truth used by mirror-sync to:
#   • detect when a user removes a default app (add to excluded-apps.list)
#   • re-apply exclusions after an image rebase reinstalls apps
# One Flatpak application ID per line. Lines starting with # are ignored.
# To add or remove default apps, update recipes/mirror-os.yml and keep this
# list in sync.

# Browsers
app.zen_browser.zen

# Media
org.kde.haruna
org.gnome.Loupe

# Communication
org.gnome.Geary
org.localsend.localsend_app
org.kde.kdeconnect

# Office
org.onlyoffice.desktopeditors
org.gnome.Calendar

# Utilities
org.gnome.Calculator
com.github.tchx84.Flatseal
it.mijorus.gearlever
io.github.dvlv.boxbuddyrs
com.usebottles.bottles

# Games
com.github.k4zmu2a.spacecadetpinball
org.gnome.Mahjongg
org.gnome.Sudoku
org.gnome.TwentyFortyEight
