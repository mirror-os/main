# Mirror OS default Flatpak apps — installed user-scope by mirror-init on first login.
# These apps are installed once and never reinstalled by subsequent OS updates.
# New apps added here will be offered to existing users via the update
# notification system (planned feature).
# One Flatpak application ID per line. Lines starting with # are ignored.

# Browsers
app.zen_browser.zen

# Media
org.kde.haruna
org.gnome.Loupe

# Communication
org.gnome.Geary
org.localsend.localsend_app

# Office
org.onlyoffice.desktopeditors
org.gnome.Calendar

# Utilities
org.gnome.Calculator
com.github.tchx84.Flatseal
it.mijorus.gearlever
io.github.dvlv.boxbuddyrs
com.usebottles.bottles

# Games
com.github.k4zmu2a.spacecadetpinball
org.gnome.Mahjongg
org.gnome.Sudoku
org.gnome.TwentyFortyEight
