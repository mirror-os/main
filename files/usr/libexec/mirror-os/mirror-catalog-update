update_nix() {
    log "Updating Nix catalog from nixpkgs (this may be slow on first run)..."

    if ! command -v nix &>/dev/null; then
        log "Nix not available — skipping Nix catalog update."
        return 1
    fi

    log "nix path: $(command -v nix); version: $(nix --version 2>&1 | head -1)"

    # Write output to a temp file — avoids shell variable size limits for
    # large JSON (nixpkgs has 100k+ packages) and lets us capture stderr
    # separately for diagnostics.
    local tmp_out tmp_err
    tmp_out=$(mktemp /tmp/mirror-nix-search.XXXXXX.json)
    tmp_err=$(mktemp /tmp/mirror-nix-search.XXXXXX.err)

    # ".*" matches all packages; empty string "" matches nothing in nix search regex
    log "Running: nix search nixpkgs '.*' --json ..."
    nix search nixpkgs ".*" --json > "$tmp_out" 2>"$tmp_err"
    local nix_exit=$?

    local nix_out_size
    nix_out_size=$(stat -c%s "$tmp_out" 2>/dev/null || echo 0)

    if [ -s "$tmp_err" ]; then
        log "nix search stderr (first 20 lines):"
        head -20 "$tmp_err" >> "$LOG_FILE"
    fi

    log "nix search exit=$nix_exit; stdout size=${nix_out_size} bytes"

    if [ "$nix_exit" -ne 0 ] || [ "$nix_out_size" -eq 0 ]; then
        log "nix search nixpkgs failed or returned empty output — preserving existing Nix catalog rows."
        rm -f "$tmp_out" "$tmp_err"
        return 1
    fi

    python3 - "$CATALOG_DB" "$tmp_out" << 'PYEOF'
import sys, json, sqlite3
from datetime import datetime, timezone

def _fts_name_extras(name: str) -> str:
    """Return extra FTS tokens for names with non-alphanumeric chars (see Flatpak phase)."""
    if not any(not c.isalnum() and not c.isspace() for c in name):
        return ''
    concat = ''.join(c.lower() for c in name if c.isalnum())
    if not concat:
        return ''
    extras = [concat]
    for i in range(1, len(concat)):
        if concat[i - 1].isdigit() != concat[i].isdigit():
            suffix = concat[i:]
            if len(suffix) >= 2 and suffix != concat:
                extras.append(suffix)
    return ' '.join(extras)

db_path  = sys.argv[1]
json_file = sys.argv[2]

try:
    with open(json_file) as f:
        data = json.load(f)
except Exception as e:
    print(f"mirror-catalog-update: failed to parse nix search JSON: {e}", file=sys.stderr)
    sys.exit(1)

# When multiple nix paths share the same last component (e.g. both
# legacyPackages.x86_64-linux.spotify and
# legacyPackages.x86_64-linux.homeassistantCustomComponents.spotify),
# keep only the shallowest one (fewest dots = top-level package).
best = {}  # attr -> (depth, val)
for key, val in data.items():
    attr  = key.split('.')[-1] if '.' in key else key
    depth = key.count('.')
    if attr not in best or depth < best[attr][0]:
        best[attr] = (depth, val)

rows     = []
fts_rows = []

for attr, (_, val) in best.items():
    # Skip internal Nix derivations not meant for end users.
    # The -unwrapped suffix marks intermediate build artifacts that are
    # never directly user-installable.
    if (attr.endswith('-unwrapped') or attr.endswith('Unwrapped') or
            attr.endswith('-wrapped')  or attr.endswith('Wrapped') or
            attr.endswith('-wrapper')):
        continue
    pname = val.get('pname', attr)
    # Skip _-prefixed attrs that represent unrelated library packages (e.g. SBCL
    # Quicklisp packages stored as _1am, _2d-array, _40ants-doc-project with
    # pname='sbcl').  Nix legitimately uses _ for apps whose names start with a
    # digit (_010editor → pname 010editor, _1password-gui → pname 1password), so
    # keep those by requiring the attr stem to share a substring with pname.
    if attr.startswith('_'):
        _stem = attr[1:].lower().replace('-', '').replace('_', '')
        _pnorm = pname.lower().replace('-', '').replace('_', '')
        if _stem not in _pnorm and _pnorm not in _stem:
            continue
    # Skip source archives that Nix treats as packages (e.g. android-ndk-r20.zip)
    _ARCHIVE_EXTS = ('.zip', '.tar.gz', '.tar.bz2', '.tar.xz', '.tgz',
                     '.jar', '.whl', '.deb', '.rpm')
    if any(pname.endswith(ext) for ext in _ARCHIVE_EXTS):
        continue
    # Skip version-prefixed language ecosystem libs (python3.13-foo, perl5.42-foo,
    # ocaml4.14-foo). These are language-internal packages, not user applications.
    _LANG_PREFIXES = ('python', 'perl', 'ocaml')
    if any(pname.startswith(p) and len(pname) > len(p) and pname[len(p)].isdigit()
           for p in _LANG_PREFIXES):
        continue
    # Skip auto-generated test/build derivation names — genuine package names
    # don't exceed 80 chars; beyond that they're typically generated strings like
    # "equal-contents-builddotnetmodule-produces-the-same-output-...".
    if len(pname) > 80:
        continue
    # Skip npm-scoped node packages.  Their attr paths use '@scope/name' syntax
    # (e.g. @antora/cli, @antfu/ni) and pnames sometimes carry the same chars.
    if '@' in attr or '/' in attr or '@' in pname or '/' in pname:
        continue
    ver   = val.get('version', '')
    desc  = val.get('description', '').replace('\n', ' ').strip()
    meta  = val.get('meta', {}) if isinstance(val.get('meta'), dict) else {}
    # Skip packages whose description announces they are deprecated.
    # Use a tight prefix match to avoid false positives (e.g. packages that
    # *replace* a deprecated one and mention it in passing).
    _desc_low = desc.lower()
    if (_desc_low.startswith('deprecated') or
            _desc_low.startswith('(deprecated')):
        continue
    # Skip auto-generated pkg-config / cmake probing derivations.  These have
    # pnames like check-pkg-config-gtk+ and descriptions "Test whether …".
    # Their attrs end up as the module name being probed (e.g. "gdk-2.0" → "0")
    # which looks completely wrong to users.
    if (pname.startswith('check-pkg-config-') or
            pname.startswith('check-cmake-config-')):
        continue
    homepage = meta.get('homepage', val.get('homepage', ''))
    if isinstance(homepage, list):
        homepage = homepage[0] if homepage else ''
    lic_raw = meta.get('license', '')
    if isinstance(lic_raw, dict):
        license_ = lic_raw.get('spdxId', lic_raw.get('fullName', ''))
    elif isinstance(lic_raw, list) and lic_raw:
        first = lic_raw[0]
        license_ = first.get('spdxId', first.get('fullName', '')) if isinstance(first, dict) else str(first)
    else:
        license_ = str(lic_raw) if lic_raw else ''
    programs_name = ''  # populated later by update_hm_options

    rows.append((attr, pname, ver, desc, '', homepage, license_, '[]', programs_name))
    _nix_extras = _fts_name_extras(pname)
    _fts_pname = f"{pname} {_nix_extras}" if _nix_extras else pname
    fts_rows.append(('nix', attr, _fts_pname, desc[:200], '', ''))

conn = sqlite3.connect(db_path, timeout=30)

# Ensure schema exists (in case only nix runs first)
conn.executescript("""
PRAGMA journal_mode=WAL;
PRAGMA synchronous=NORMAL;

CREATE TABLE IF NOT EXISTS flatpak_apps (
    app_id TEXT PRIMARY KEY, name TEXT NOT NULL DEFAULT '', summary TEXT NOT NULL DEFAULT '',
    description TEXT NOT NULL DEFAULT '', version TEXT NOT NULL DEFAULT '',
    release_date TEXT NOT NULL DEFAULT '', release_timestamp INTEGER NOT NULL DEFAULT 0,
    developer TEXT NOT NULL DEFAULT '', license TEXT NOT NULL DEFAULT '',
    homepage TEXT NOT NULL DEFAULT '', bugtracker_url TEXT NOT NULL DEFAULT '',
    donation_url TEXT NOT NULL DEFAULT '', categories TEXT NOT NULL DEFAULT '[]',
    keywords TEXT NOT NULL DEFAULT '[]', icon_name TEXT NOT NULL DEFAULT '',
    screenshots TEXT NOT NULL DEFAULT '[]', content_rating TEXT NOT NULL DEFAULT '',
    flatpak_ref TEXT NOT NULL DEFAULT '', releases_json TEXT NOT NULL DEFAULT '[]',
    verified INTEGER NOT NULL DEFAULT 0, monthly_downloads INTEGER NOT NULL DEFAULT 0,
    icon_local_path TEXT NOT NULL DEFAULT ''
);
CREATE TABLE IF NOT EXISTS nix_packages (
    attr TEXT PRIMARY KEY, pname TEXT NOT NULL, version TEXT NOT NULL DEFAULT '',
    description TEXT NOT NULL DEFAULT '', long_description TEXT NOT NULL DEFAULT '',
    homepage TEXT NOT NULL DEFAULT '', license TEXT NOT NULL DEFAULT '',
    maintainers TEXT NOT NULL DEFAULT '[]', programs_name TEXT NOT NULL DEFAULT ''
);
CREATE TABLE IF NOT EXISTS catalog_meta (
    source TEXT PRIMARY KEY, updated_at TEXT NOT NULL, row_count INTEGER NOT NULL DEFAULT 0
);
CREATE VIRTUAL TABLE IF NOT EXISTS catalog_fts USING fts5(
    source, id, name, description, developer, categories,
    tokenize = 'unicode61 remove_diacritics 1'
);
CREATE TABLE IF NOT EXISTS app_map (
    slug             TEXT PRIMARY KEY,
    flatpak_id       TEXT,
    nix_attr         TEXT,
    display_name     TEXT NOT NULL DEFAULT '',
    preferred_source TEXT NOT NULL DEFAULT 'flatpak'
);
CREATE INDEX IF NOT EXISTS idx_app_map_flatpak ON app_map(flatpak_id);
CREATE INDEX IF NOT EXISTS idx_app_map_nix ON app_map(nix_attr);
""")

# Migration guard
for col_def in [
    "ALTER TABLE flatpak_apps ADD COLUMN icon_local_path TEXT NOT NULL DEFAULT ''",
    "ALTER TABLE nix_packages ADD COLUMN long_description TEXT NOT NULL DEFAULT ''",
    "ALTER TABLE nix_packages ADD COLUMN maintainers TEXT NOT NULL DEFAULT '[]'",
    "ALTER TABLE app_map ADD COLUMN preferred_source TEXT NOT NULL DEFAULT 'flatpak'",
]:
    try:
        conn.execute(col_def)
    except Exception:
        pass

now = datetime.now(tz=timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')

with conn:
    conn.execute("DELETE FROM nix_packages")
    conn.executemany(
        "INSERT OR REPLACE INTO nix_packages"
        "(attr,pname,version,description,long_description,homepage,license,maintainers,programs_name)"
        " VALUES (?,?,?,?,?,?,?,?,?)",
        rows,
    )
    conn.execute("DELETE FROM catalog_fts WHERE source='nix'")
    conn.executemany(
        "INSERT INTO catalog_fts(source,id,name,description,developer,categories) VALUES (?,?,?,?,?,?)",
        fts_rows,
    )
    conn.execute("""
        INSERT OR REPLACE INTO catalog_meta(source, updated_at, row_count)
        VALUES ('nix', ?, ?)
    """, (now, len(rows)))

conn.close()
print(f"Nix catalog updated: {len(rows)} packages indexed.")
PYEOF
    local rc=$?
    rm -f "$tmp_out" "$tmp_err"
    if [ $rc -eq 0 ]; then
        log "Nix catalog updated successfully."
    else
        log "Nix catalog update failed (exit $rc)."
        return $rc
    fi
}

# ── Nix metadata enrichment ──────────────────────────────────────────────────

update_nix_meta() {
    log "Checking Nix metadata enrichment..."

    if ! command -v nix &>/dev/null; then
        log "Nix not available — skipping Nix metadata enrichment."
        return 1
    fi

    # Detect current nixpkgs revision from the flake registry
    local nixpkgs_rev
    nixpkgs_rev=$(nix eval --raw --impure --expr '(builtins.getFlake "nixpkgs").rev' 2>/dev/null || echo "")
    if [ -z "$nixpkgs_rev" ]; then
        log "Could not determine nixpkgs revision — skipping Nix metadata enrichment."
        return 1
    fi

    # Check if we already enriched for this exact revision
    local stored_rev
    stored_rev=$(sqlite3 "$CATALOG_DB" \
        "SELECT updated_at FROM catalog_meta WHERE source='nix-meta'" 2>/dev/null || echo "")
    if [ "$stored_rev" = "$nixpkgs_rev" ]; then
        log "Nix metadata already enriched for nixpkgs rev ${nixpkgs_rev:0:12} — skipping."
        return 0
    fi

    log "Enriching Nix package metadata for nixpkgs rev ${nixpkgs_rev:0:12}..."
    log "This may take 20-40 min on first run or after a nixpkgs update."

    python3 - "$CATALOG_DB" "$nixpkgs_rev" << 'PYEOF'
import sys, json, sqlite3, subprocess, time, os
from datetime import datetime, timezone
from concurrent.futures import ThreadPoolExecutor, as_completed

db_path      = sys.argv[1]
nixpkgs_rev  = sys.argv[2]

# Worker count for parallel nix eval (CPU/memory-heavy).
# Override with MIRROR_NIX_WORKERS env var.
_env_workers = os.environ.get('MIRROR_NIX_WORKERS', '')
MAX_WORKERS = int(_env_workers) if _env_workers.isdigit() and int(_env_workers) > 0 \
    else min(os.cpu_count() or 2, 4)

conn = sqlite3.connect(db_path, timeout=60)

# Migration guard — add nix-meta row to catalog_meta if missing
try:
    conn.execute("INSERT OR IGNORE INTO catalog_meta(source, updated_at, row_count) VALUES ('nix-meta', '', 0)")
    conn.commit()
except Exception:
    pass

attrs = [row[0] for row in conn.execute("SELECT attr FROM nix_packages").fetchall()]
total = len(attrs)

CHUNK   = 200
TIMEOUT = 180  # seconds per chunk

n_chunks = (total + CHUNK - 1) // CHUNK
print(f"Enriching metadata for {total} Nix packages in {n_chunks} chunks "
      f"({MAX_WORKERS} workers)...", flush=True)

# Build all chunk attr lists up front
chunks = [attrs[i:i+CHUNK] for i in range(0, total, CHUNK)]

NIX_EXPR_TEMPLATE = r"""
let
  nixpkgs = builtins.getFlake "nixpkgs";
  pkgs    = nixpkgs.legacyPackages.x86_64-linux;
  attrs   = [ {attrs_nix} ];
  wanted  = builtins.listToAttrs (map (n: {{ name = n; value = null; }}) attrs);
  subset  = builtins.intersectAttrs wanted pkgs;
  safe = thunk: default:
    let r = builtins.tryEval thunk; in
    if r.success then r.value else default;
in
builtins.mapAttrs (name: pkg:
  let
    m_r = builtins.tryEval (pkg.meta or {{}});
    m   = if m_r.success && builtins.isAttrs m_r.value then m_r.value else {{}};

    longDesc = safe (m.longDescription or "") "";

    hp_raw   = safe (m.homepage or "") "";
    homepage = if builtins.isList hp_raw
               then (if hp_raw == [] then "" else safe (builtins.head hp_raw) "")
               else hp_raw;

    lic_raw  = safe (m.license or null) null;
    license  =
      if lic_raw == null then ""
      else if builtins.isAttrs lic_raw
           then safe (lic_raw.spdxId or (lic_raw.fullName or "")) ""
      else if builtins.isList lic_raw && lic_raw != []
           then (let f = safe (builtins.head lic_raw) null; in
                 if f != null && builtins.isAttrs f
                 then safe (f.spdxId or (f.fullName or "")) ""
                 else "")
      else "";

    mts_raw     = safe (m.maintainers or []) [];
    maintainers = map
      (mm:
        let gh = safe (mm.github or "") "";
            nm = safe (mm.name   or "") "";
        in if gh != "" then gh else nm)
      (if builtins.isList mts_raw then mts_raw else []);
  in
  {{ inherit longDesc homepage license maintainers; }}
) subset
"""

def eval_chunk(ci, chunk):
    """Evaluate one chunk of attrs. Returns (chunk_index, dict of attr->meta)."""
    attrs_nix = ' '.join(f'"{a}"' for a in chunk)
    expr = NIX_EXPR_TEMPLATE.format(attrs_nix=attrs_nix)
    try:
        result = subprocess.run(
            ["nix", "eval", "--json", "--impure", "--expr", expr],
            capture_output=True, text=True, timeout=TIMEOUT,
        )
        if result.returncode != 0:
            snippet = result.stderr.strip()[:300]
            print(f"    Chunk {ci+1}/{n_chunks} failed: {snippet}", flush=True)
            return (ci, {})
        return (ci, json.loads(result.stdout))
    except subprocess.TimeoutExpired:
        print(f"    Chunk {ci+1}/{n_chunks} timed out after {TIMEOUT}s", flush=True)
        return (ci, {})
    except Exception as e:
        print(f"    Chunk {ci+1}/{n_chunks} error: {e}", flush=True)
        return (ci, {})

total_updated = 0
t_start = time.monotonic()
done_count = 0

with ThreadPoolExecutor(max_workers=MAX_WORKERS) as pool:
    futures = {pool.submit(eval_chunk, i, chunk): i
               for i, chunk in enumerate(chunks)}

    for future in as_completed(futures):
        ci, data = future.result()
        done_count += 1

        updated = 0
        if data:
            with conn:
                for attr, meta in data.items():
                    if not meta:
                        continue
                    ld  = meta.get('longDesc', '')
                    hp  = meta.get('homepage', '')
                    lic = meta.get('license', '')
                    mts = json.dumps([m for m in meta.get('maintainers', []) if m])

                    conn.execute("""
                        UPDATE nix_packages SET
                          long_description = CASE WHEN :ld  != ''   THEN :ld  ELSE long_description END,
                          homepage         = CASE WHEN :hp  != ''   THEN :hp  ELSE homepage         END,
                          license          = CASE WHEN :lic != ''   THEN :lic ELSE license          END,
                          maintainers      = CASE WHEN :mts != '[]' THEN :mts ELSE maintainers      END
                        WHERE attr = :attr
                    """, {'ld': ld, 'hp': hp, 'lic': lic, 'mts': mts, 'attr': attr})
                    updated += 1

        total_updated += updated
        elapsed = time.monotonic() - t_start
        print(f"  Chunk {ci+1}/{n_chunks}: {updated} updated "
              f"({done_count}/{n_chunks} done, {elapsed:.0f}s elapsed)", flush=True)

# Record the nixpkgs rev so we skip on next run if nothing changed
now = datetime.now(tz=timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
with conn:
    conn.execute(
        "INSERT OR REPLACE INTO catalog_meta(source, updated_at, row_count) VALUES ('nix-meta', ?, ?)",
        (nixpkgs_rev, total_updated),
    )
conn.close()

elapsed_total = time.monotonic() - t_start
print(f"Nix metadata enrichment complete: {total_updated} packages enriched in {elapsed_total:.1f}s.")
PYEOF
    local rc=$?
    if [ $rc -eq 0 ]; then
        log "Nix metadata enrichment complete."
    else
        log "Nix metadata enrichment failed (exit $rc)."
        return $rc
    fi
}

fi  # end BUILD_MODE functions

# ══════════════════════════════════════════════════════════════════════════════
# Orchestration
# ══════════════════════════════════════════════════════════════════════════════

log "Starting catalog update (mode: $([ $BUILD_MODE -eq 1 ] && echo build || echo download), source: $SOURCE)..."

if [ "$BUILD_MODE" -eq 1 ]; then
    # ── Build mode (catalog-data CI) ─────────────────────────────────────────
    case "$SOURCE" in
        flatpak)
            update_flatpak || true
            if [ $NO_MEDIA -eq 0 ]; then
                cache_flatpak_media || true
            else
                log "Skipping media download (--no-media)."
            fi
            build_app_map
            ;;
        nix)
            update_nix      || true
            update_nix_meta || true
            build_app_map
            ;;
        nix-meta)
            update_nix_meta || true
            ;;
        hm-options)
            update_hm_options || true
            ;;
        all)
            # Flatpak and Nix pipelines write to independent tables — run in parallel.
            (
                update_flatpak || true
                if [ $NO_MEDIA -eq 0 ]; then
                    cache_flatpak_media || true
                else
                    log "Skipping media download (--no-media)."
                fi
            ) &
            flatpak_pid=$!

            (
                update_nix || true
                # nix-meta and hm-options update different columns — run in parallel
                update_nix_meta &
                meta_pid=$!
                update_hm_options &
                hm_pid=$!
                wait $meta_pid $hm_pid
            ) &
            nix_pid=$!

            wait $flatpak_pid $nix_pid
            build_app_map
            ;;
    esac
else
    # ── Download mode (on-device, default) ───────────────────────────────────
    case "$SOURCE" in
        all)
            download_catalog || true
            if [ $NO_MEDIA -eq 0 ]; then
                generate_pending_downloads || true
                cache_flatpak_media || true
            fi
            build_app_map    || true
            update_hm_options || true
            ;;
        hm-options)
            update_hm_options || true
            ;;
    esac
fi

log "Catalog update complete."
