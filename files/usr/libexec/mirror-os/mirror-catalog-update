import sys, os, json, sqlite3, time, threading
import urllib.request
from concurrent.futures import ThreadPoolExecutor, as_completed

db_path    = sys.argv[1]
media_dir  = sys.argv[2]
icons_dir  = os.path.join(media_dir, 'icons')
ss_base_dir = os.path.join(media_dir, 'screenshots')
pending_file = os.path.join(media_dir, '.pending_downloads.json')

with open(pending_file) as f:
    pending = json.load(f)

remote_icons       = pending.get('icons', [])
remote_screenshots = pending.get('screenshots', [])

UA = {'User-Agent': 'mirror-catalog-update/1.0'}
ICON_TIMEOUT = 8
SS_TIMEOUT   = 10
# Total wall-clock budget for all media downloads (30 min)
TOTAL_BUDGET = 1800
t_start = time.monotonic()

# Worker count: network-bound, so 2x CPU cores up to 16 max.
# Override with MIRROR_MEDIA_WORKERS env var.
_env_workers = os.environ.get('MIRROR_MEDIA_WORKERS', '')
MAX_WORKERS = int(_env_workers) if _env_workers.isdigit() and int(_env_workers) > 0 \
    else min((os.cpu_count() or 2) * 2, 16)

budget_expired = threading.Event()

def budget_remaining():
    return TOTAL_BUDGET - (time.monotonic() - t_start)

def fetch(url, timeout):
    req = urllib.request.Request(url, headers=UA)
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return r.read()

# ── Icons (parallel) ─────────────────────────────────────────────────────
def download_icon(app_id, url):
    if budget_expired.is_set():
        return None
    dst = os.path.join(icons_dir, f'{app_id}.png')
    if os.path.isfile(dst) and os.path.getsize(dst) > 0:
        return (dst, app_id)
    try:
        data = fetch(url, ICON_TIMEOUT)
        if data:
            with open(dst, 'wb') as f:
                f.write(data)
            return (dst, app_id)
    except Exception:
        pass
    return None

icon_updates = []
n_icons = len(remote_icons)
print(f"Downloading {n_icons} missing icons ({MAX_WORKERS} workers)...", flush=True)

with ThreadPoolExecutor(max_workers=MAX_WORKERS) as pool:
    futures = {pool.submit(download_icon, aid, url): aid
               for aid, url in remote_icons}
    done_count = 0
    for future in as_completed(futures):
        done_count += 1
        if budget_remaining() <= 0 and not budget_expired.is_set():
            budget_expired.set()
            print(f"  Budget exhausted after {done_count} icons; cancelling remaining.", flush=True)
        result = future.result()
        if result is not None:
            icon_updates.append(result)
        if done_count % 100 == 0:
            print(f"  Icons: {done_count}/{n_icons} ({time.monotonic()-t_start:.0f}s elapsed)...", flush=True)

# ── Screenshots (parallel per app) ───────────────────────────────────────
def download_app_screenshots(app_id, screenshots_raw):
    if budget_expired.is_set():
        return None
    ss_dir = os.path.join(ss_base_dir, app_id)
    os.makedirs(ss_dir, exist_ok=True)
    screenshots = []
    for i, ss in enumerate(screenshots_raw):
        if budget_expired.is_set():
            screenshots.append(dict(ss, local_path=''))
            continue
        local_path = os.path.join(ss_dir, f'{i}.jpg')
        if os.path.isfile(local_path) and os.path.getsize(local_path) > 0:
            screenshots.append(dict(ss, local_path=local_path))
            continue
        try:
            data = fetch(ss['url'], SS_TIMEOUT)
            if data:
                with open(local_path, 'wb') as f:
                    f.write(data)
                screenshots.append(dict(ss, local_path=local_path))
                continue
        except Exception:
            pass
        screenshots.append(dict(ss, local_path=''))
    return (app_id, json.dumps(screenshots))

# Reset budget event for screenshot phase (icons may have set it prematurely
# while in-flight futures were still completing).
if not budget_expired.is_set() or budget_remaining() > 0:
    budget_expired.clear()

ss_updates = {}
n_apps = len(remote_screenshots)
print(f"Downloading screenshots for {n_apps} apps ({MAX_WORKERS} workers)...", flush=True)

with ThreadPoolExecutor(max_workers=MAX_WORKERS) as pool:
    futures = {pool.submit(download_app_screenshots, aid, ss_raw): aid
               for aid, ss_raw in remote_screenshots}
    done_count = 0
    for future in as_completed(futures):
        done_count += 1
        if budget_remaining() <= 0 and not budget_expired.is_set():
            budget_expired.set()
            print(f"  Budget exhausted after {done_count}/{n_apps} apps; cancelling remaining.", flush=True)
        result = future.result()
        if result is not None:
            app_id, ss_json = result
            ss_updates[app_id] = ss_json
        if done_count % 200 == 0:
            print(f"  Screenshots: {done_count}/{n_apps} apps ({time.monotonic()-t_start:.0f}s elapsed)...", flush=True)

# ── Write updates back to DB ──────────────────────────────────────────────
if icon_updates or ss_updates:
    conn = sqlite3.connect(db_path, timeout=30)
    with conn:
        for local_path, app_id in icon_updates:
            conn.execute("UPDATE flatpak_apps SET icon_local_path=? WHERE app_id=?", (local_path, app_id))
        for app_id, ss_json in ss_updates.items():
            conn.execute("UPDATE flatpak_apps SET screenshots=? WHERE app_id=?", (ss_json, app_id))
    conn.close()

os.remove(pending_file)
elapsed = time.monotonic() - t_start
print(f"Phase 2 complete: {len(icon_updates)} icons, {len(ss_updates)} apps with screenshots "
      f"updated in {elapsed:.1f}s.", flush=True)
PYEOF
    local rc=$?
    if [ $rc -eq 0 ]; then
        log "Flatpak media cache updated (Phase 2 complete)."
    else
        log "Flatpak media cache update failed (exit $rc)."
    fi
}

