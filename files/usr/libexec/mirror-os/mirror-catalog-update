import xml.etree.ElementTree as ET

def _fts_name_extras(name: str) -> str:
    """Return extra FTS tokens for app names that contain non-alphanumeric chars.

    The unicode61 tokenizer splits on special characters, so '0 A.D.' produces
    tokens ['0','a','d'] — a query like '0ad' or '0 ad' can never match.
    Appending the concatenated form ('0ad') and its digit/letter-boundary suffixes
    ('ad') to the FTS name column creates the missing tokens.
    Plain names (letters + spaces only) are returned unchanged.
    """
    if not any(not c.isalnum() and not c.isspace() for c in name):
        return ''
    concat = ''.join(c.lower() for c in name if c.isalnum())
    if not concat:
        return ''
    extras = [concat]
    for i in range(1, len(concat)):
        if concat[i - 1].isdigit() != concat[i].isdigit():
            suffix = concat[i:]
            if len(suffix) >= 2 and suffix != concat:
                extras.append(suffix)
    return ' '.join(extras)

