# ── Cross-source app_map builder ─────────────────────────────────────────────

build_app_map() {
    log "Building cross-source app_map..."

    python3 - "$CATALOG_DB" << 'PYEOF'
import sys, sqlite3, re

db_path = sys.argv[1]

# ── Slug derivation constants ────────────────────────────────────────────────
KNOWN_TLDS  = {'com','org','net','io','app','dev','me','co','edu','gov','uk','de','fr'}
KNOWN_HOSTS = {'github','gitlab','bitbucket','codeberg','sr'}
KNOWN_ORGS  = {'gnome','kde','xfce','freedesktop','mozilla','apache','microsoft'}
TRAIL_SFXS  = {'client','desktop','app','stable','beta','nightly','gtk','gtk3','gtk4','bin'}

def flatpak_slug(app_id):
    parts = app_id.lower().split('.')
    if parts and parts[0] in KNOWN_TLDS:              parts = parts[1:]
    if parts and parts[0] in KNOWN_HOSTS:             parts = parts[1:]
    if len(parts) > 1 and parts[0] in KNOWN_ORGS:    parts = parts[1:]
    while len(parts) > 1 and parts[-1] in TRAIL_SFXS: parts = parts[:-1]
    # Deduplicate consecutive identical parts so com.slack.Slack → 'slack', not 'slack-slack'
    deduped = [parts[0]] if parts else []
    for p in parts[1:]:
        if p != deduped[-1]:
            deduped.append(p)
    parts = deduped
    slug = '-'.join(parts)
    slug = re.sub(r'[^a-z0-9-]', '-', slug)
    slug = re.sub(r'-+', '-', slug).strip('-')
    return slug or app_id.lower().replace('.', '-')

def nix_slug(attr):
    # Skip language sub-namespace packages (not user-facing apps)
    if re.match(r'^(python|perl|ruby|lua|node|haskell)', attr):
        return ''
    s = attr.lower()
    for sfx in ('-git', '-bin', '-unwrapped', '-wrapped'):
        if s.endswith(sfx):
            s = s[:-len(sfx)]
    return s

# ── Load both catalogs ───────────────────────────────────────────────────────
conn = sqlite3.connect(db_path, timeout=30)

flatpak_rows = conn.execute("SELECT app_id, name FROM flatpak_apps").fetchall()
nix_rows     = conn.execute("SELECT attr, pname FROM nix_packages").fetchall()

# Build slug → (id, name) dicts
fp_slugs = {}
for app_id, name in flatpak_rows:
    s = flatpak_slug(app_id)
    if s and s not in fp_slugs:
        fp_slugs[s] = (app_id, name)

nix_slugs = {}
for attr, pname in nix_rows:
    s = nix_slug(attr)
    if s and s not in nix_slugs:
        nix_slugs[s] = (attr, pname)

# ── Build unified rows ───────────────────────────────────────────────────────
all_slugs = set(fp_slugs) | set(nix_slugs)
map_rows = []
for slug in sorted(all_slugs):
    fp_id, fp_name = fp_slugs.get(slug, (None, None))
    nix_attr, nix_name = nix_slugs.get(slug, (None, None))
    display_name = fp_name or nix_name or slug
    preferred = 'flatpak' if fp_id else 'nix'
    map_rows.append((slug, fp_id, nix_attr, display_name, preferred))

# ── Migration guard ───────────────────────────────────────────────────────────
for col_def in [
    "ALTER TABLE flatpak_apps ADD COLUMN icon_local_path TEXT NOT NULL DEFAULT ''",
    "ALTER TABLE nix_packages ADD COLUMN long_description TEXT NOT NULL DEFAULT ''",
    "ALTER TABLE nix_packages ADD COLUMN maintainers TEXT NOT NULL DEFAULT '[]'",
    "ALTER TABLE app_map ADD COLUMN preferred_source TEXT NOT NULL DEFAULT 'flatpak'",
]:
    try:
        conn.execute(col_def)
    except Exception:
        pass

# ── Replace app_map ──────────────────────────────────────────────────────────
with conn:
    conn.execute("DELETE FROM app_map")
    conn.executemany(
        "INSERT INTO app_map(slug, flatpak_id, nix_attr, display_name, preferred_source) VALUES (?,?,?,?,?)",
        map_rows,
    )

conn.close()

both  = sum(1 for _, fp, nx, _, _ in map_rows if fp and nx)
total = len(map_rows)
print(f"app_map built: {total} slugs ({both} cross-source matches).")
PYEOF
    local rc=$?
    if [ $rc -eq 0 ]; then
        log "app_map built successfully."
    else
        log "app_map build failed (exit $rc)."
    fi
}

# ── Run ──────────────────────────────────────────────────────────────────────

log "Starting catalog update (source: $SOURCE, media: $([ $NO_MEDIA -eq 1 ] && echo skip || echo enabled))..."

case "$SOURCE" in
    flatpak)
        update_flatpak || true
        build_app_map
        ;;
    nix)
        update_nix || true
        build_app_map
        ;;
    all)
        update_flatpak || true
        update_nix     || true
        build_app_map
        ;;
esac

if [ $NO_MEDIA -eq 0 ]; then
    cache_flatpak_media || true
else
    log "Skipping media download (--no-media)."
fi

log "Catalog update complete."
