#!/usr/bin/env bash
# mirror-catalog-update — Mirror OS app catalog database updater
# Populates ~/.local/share/mirror-os/catalog.db (SQLite, WAL mode) with:
#   - All Flathub apps from the local AppStream XML cache (no network required)
#   - All nixpkgs packages from `nix search nixpkgs "" --json`
#
# Usage:
#   mirror-catalog-update [--source flatpak|nix|all]
#
# Run by mirror-os-catalog.timer (10 min after boot, then hourly).
# Safe to run manually: flock prevents concurrent executions.

set -uo pipefail

export PATH="/nix/var/nix/profiles/default/bin:$HOME/.nix-profile/bin:$PATH"

CATALOG_DB="$HOME/.local/share/mirror-os/catalog.db"
LOCK_FILE="/tmp/mirror-catalog-update.lock"
LOG_FILE="$HOME/.local/share/mirror-os/catalog-update.log"
APPSTREAM_GZ="/var/lib/flatpak/appstream/flathub/x86_64/active/appstream.xml.gz"
APPSTREAM_XML="/var/lib/flatpak/appstream/flathub/x86_64/active/appstream.xml"
MEDIA_DIR="$HOME/.local/share/mirror-os/media"

# ── Helpers ──────────────────────────────────────────────────────────────────

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE" >&2; }

# Rotate log if over 1 MB
[ -f "$LOG_FILE" ] && [ "$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)" -gt 1048576 ] \
    && mv "$LOG_FILE" "${LOG_FILE}.1"

# Acquire lock — exit silently if another instance is running
exec 9>"$LOCK_FILE"
if ! flock -w 5 9; then
    log "Another mirror-catalog-update is running; exiting."
    exit 0
fi

# ── Argument parsing ─────────────────────────────────────────────────────────

SOURCE="all"
NO_MEDIA=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --source) SOURCE="$2"; shift 2 ;;
        --no-media) NO_MEDIA=1; shift ;;
        *) echo "Usage: mirror-catalog-update [--source flatpak|nix|all] [--no-media]" >&2; exit 1 ;;
    esac
done

case "$SOURCE" in
    flatpak|nix|all) ;;
    *) echo "mirror-catalog-update: unknown source '$SOURCE'" >&2; exit 1 ;;
esac

# ── Ensure directories exist ─────────────────────────────────────────────────

mkdir -p "$(dirname "$CATALOG_DB")"
mkdir -p "$MEDIA_DIR/icons"
mkdir -p "$MEDIA_DIR/screenshots"

# ── Flatpak catalog update ───────────────────────────────────────────────────

update_flatpak() {
    log "Updating Flatpak catalog from AppStream XML (Phase 1: parse + index)..."

    local appstream_path=""
    if [ -f "$APPSTREAM_GZ" ]; then
        appstream_path="$APPSTREAM_GZ"
    elif [ -f "$APPSTREAM_XML" ]; then
        appstream_path="$APPSTREAM_XML"
    else
        log "AppStream XML not found at $APPSTREAM_GZ or $APPSTREAM_XML — skipping Flatpak update."
        log "Tip: run 'flatpak update' to refresh the Flathub metadata cache."
        return 1
    fi

    # Phase 1: parse XML, copy only already-present local icons, write DB.
    # No network calls — completes in seconds.
    python3 - "$CATALOG_DB" "$appstream_path" "$MEDIA_DIR" << 'PYEOF'
import sys, os, gzip, json, sqlite3, re, shutil, time
from datetime import datetime, timezone
from html.parser import HTMLParser
import xml.etree.ElementTree as ET

db_path      = sys.argv[1]
appstream    = sys.argv[2]
media_dir    = sys.argv[3]
icons_dir    = os.path.join(media_dir, 'icons')
ss_base_dir  = os.path.join(media_dir, 'screenshots')
FLATPAK_ICON_DIR = "/var/lib/flatpak/appstream/flathub/x86_64/active/icons"

# ── HTML tag stripper ──────────────────────────────────────────────────────
class TagStripper(HTMLParser):
    def __init__(self):
        super().__init__()
        self._parts = []
    def handle_data(self, data):
        self._parts.append(data)
    def get_text(self):
        return ' '.join(p.strip() for p in self._parts if p.strip())

# xml:lang attribute key as used by Python's ElementTree
_XML_LANG = '{http://www.w3.org/XML/1998/namespace}lang'

def elem_text(elem, tag):
    # Prefer the element with no xml:lang (unlocalized / default English).
    # Fall back to the first element found if every instance is localized.
    fallback = None
    for child in elem.findall(tag):
        if _XML_LANG not in child.attrib:
            return (child.text or '').strip()
        if fallback is None:
            fallback = child
    return (fallback.text or '').strip() if fallback is not None else ''

def oars_rating(comp):
    cr = comp.find("content_rating[@type='oars-1.1']")
    if cr is None:
        cr = comp.find('content_rating')
    if cr is None:
        return 'all'
    values = [v.text or '' for v in cr.findall('content_attribute')]
    if any(v == 'intense' for v in values):
        return 'intense'
    if any(v == 'moderate' for v in values):
        return 'moderate'
    return 'all'

def desc_to_text(comp):
    # Prefer <description> without xml:lang (unlocalized / default English)
    desc_elem = None
    for child in comp.findall('description'):
        if _XML_LANG not in child.attrib:
            desc_elem = child
            break
    if desc_elem is None:
        desc_elem = comp.find('description')
    if desc_elem is None:
        return ''
    try:
        raw = ET.tostring(desc_elem, encoding='unicode', method='html')
        s = TagStripper()
        s.feed(raw)
        return s.get_text()
    except Exception:
        return (desc_elem.text or '').strip()

# ── Parse AppStream XML ────────────────────────────────────────────────────
t0 = time.monotonic()
print("Parsing AppStream XML...", flush=True)
opener = gzip.open if appstream.endswith('.gz') else open
try:
    with opener(appstream, 'rb') as f:
        root = ET.parse(f).getroot()
except Exception as e:
    print(f"mirror-catalog-update: failed to parse AppStream XML: {e}", file=sys.stderr)
    sys.exit(1)
print(f"  XML parsed in {time.monotonic()-t0:.1f}s", flush=True)

rows       = []
fts_rows   = []
# Remote icon URLs collected for Phase 2 (downloaded separately, no network here)
remote_icons = []  # (app_id, url)
# Screenshot URLs collected for Phase 2
remote_screenshots = []  # (app_id, [(url, caption, width, height)])

n = 0
t1 = time.monotonic()
for comp in root.iter('component'):
    ctype = comp.get('type', '')
    if ctype not in ('desktop-application', 'console-application', 'desktop'):
        continue

    app_id = elem_text(comp, 'id')
    if not app_id:
        continue

    n += 1
    if n % 200 == 0:
        elapsed = time.monotonic() - t1
        print(f"  Processed {n} apps ({elapsed:.1f}s)...", flush=True)

    name    = elem_text(comp, 'name')
    summary = elem_text(comp, 'summary')
    desc    = desc_to_text(comp)

    developer = elem_text(comp, 'developer_name')
    if not developer:
        dev_elem = comp.find('developer')
        if dev_elem is not None:
            developer = elem_text(dev_elem, 'name')

    license_ = elem_text(comp, 'project_license')

    homepage = bugtracker = donation = ''
    for url_elem in comp.findall('url'):
        utype = url_elem.get('type', '')
        val   = (url_elem.text or '').strip()
        if utype == 'homepage':     homepage   = val
        elif utype == 'bugtracker': bugtracker = val
        elif utype == 'donation':   donation   = val

    cats = [c.text.strip() for c in comp.findall('categories/category') if c.text]
    # Only include keywords from the unlocalized <keywords> block
    kws  = [k.text.strip() for k in comp.findall('keywords/keyword')
            if k.text and _XML_LANG not in k.attrib]

    # Icon: prefer cached (already on disk from flatpak), collect remote URL for later
    icon_name  = ''
    best_size  = 0
    remote_icon_url = ''
    for icon in comp.findall('icon'):
        itype = icon.get('type', '')
        if itype == 'cached':
            try:
                sz = int(icon.get('width', 0))
            except ValueError:
                sz = 0
            if sz > best_size or not icon_name:
                icon_name = re.sub(r'\.(png|svg|xpm)$', '', (icon.text or '').strip(), flags=re.IGNORECASE)
                best_size = sz
        elif itype == 'remote' and not remote_icon_url:
            remote_icon_url = (icon.text or '').strip()

    # Try to resolve icon from local flatpak cache (no network)
    icon_local_path = ''
    if icon_name:
        dst_icon = os.path.join(icons_dir, f'{app_id}.png')
        if os.path.isfile(dst_icon) and os.path.getsize(dst_icon) > 0:
            icon_local_path = dst_icon
        else:
            for size in ('128x128', '64x64', '128x128@2'):
                if icon_local_path:
                    break
                for ext in ('.png', '.svg', ''):
                    src = os.path.join(FLATPAK_ICON_DIR, size, f'{icon_name}{ext}')
                    if os.path.isfile(src):
                        try:
                            shutil.copy2(src, dst_icon)
                            icon_local_path = dst_icon
                        except Exception:
                            pass
                        break
            # Queue remote download for Phase 2 if still missing
            if not icon_local_path and remote_icon_url:
                remote_icons.append((app_id, remote_icon_url))

    # Screenshots: build metadata from XML; local paths resolved in Phase 2
    screenshots_raw = []
    for ss in comp.findall('screenshots/screenshot'):
        caption = elem_text(ss, 'caption')
        for img in ss.findall('image'):
            if img.get('type', 'source') == 'source':
                url = (img.text or '').strip()
                if url:
                    screenshots_raw.append({
                        'url': url, 'caption': caption,
                        'width':  int(img.get('width',  0) or 0),
                        'height': int(img.get('height', 0) or 0),
                    })
                break

    # Resolve already-cached screenshots; queue the rest for Phase 2
    screenshots = []
    if screenshots_raw:
        ss_dir = os.path.join(ss_base_dir, app_id)
        need_download = False
        for i, ss in enumerate(screenshots_raw):
            local_path = os.path.join(ss_dir, f'{i}.jpg')
            if os.path.isfile(local_path) and os.path.getsize(local_path) > 0:
                screenshots.append(dict(ss, local_path=local_path))
            else:
                screenshots.append(dict(ss, local_path=''))
                need_download = True
        if need_download:
            remote_screenshots.append((app_id, screenshots_raw))

    content_rating = oars_rating(comp)

    flatpak_ref = ''
    bundle = comp.find("bundle[@type='flatpak']")
    if bundle is not None:
        flatpak_ref = (bundle.text or '').strip()

    releases_out = []
    version = release_date = ''
    release_timestamp = 0
    releases_elem = comp.find('releases')
    if releases_elem is not None:
        for rel in list(releases_elem.findall('release'))[:10]:
            rv    = rel.get('version', '')
            rts   = rel.get('timestamp', '')
            rdate = rel.get('date', '')
            if not rdate and rts and rts.isdigit():
                try:
                    rdate = datetime.fromtimestamp(int(rts), tz=timezone.utc).strftime('%Y-%m-%d')
                except Exception:
                    rdate = ''
            ts_int = int(rts) if rts and rts.isdigit() else 0
            rdesc  = desc_to_text(rel) if rel.find('description') is not None else ''
            releases_out.append({'version': rv, 'date': rdate, 'timestamp': ts_int, 'description': rdesc})
            if not version:
                version = rv; release_date = rdate; release_timestamp = ts_int

    verified = 0
    for val_elem in comp.findall('custom/value'):
        if val_elem.get('key') == 'flathub::verification::verified':
            verified = 1 if (val_elem.text or '').strip().lower() in ('true', '1') else 0

    rows.append((
        app_id, name, summary, desc,
        version, release_date, release_timestamp,
        developer, license_, homepage, bugtracker, donation,
        json.dumps(cats), json.dumps(kws), icon_name,
        json.dumps(screenshots), content_rating, flatpak_ref,
        json.dumps(releases_out), verified, 0, icon_local_path,
    ))
    fts_rows.append(('flatpak', app_id, name, summary or desc[:200], developer, ' '.join(cats)))

print(f"  Parsed {n} apps in {time.monotonic()-t1:.1f}s; writing DB...", flush=True)

# ── Write to DB ────────────────────────────────────────────────────────────
conn = sqlite3.connect(db_path, timeout=30)
conn.executescript("""
PRAGMA journal_mode=WAL;
PRAGMA synchronous=NORMAL;

CREATE TABLE IF NOT EXISTS flatpak_apps (
    app_id            TEXT PRIMARY KEY,
    name              TEXT NOT NULL DEFAULT '',
    summary           TEXT NOT NULL DEFAULT '',
    description       TEXT NOT NULL DEFAULT '',
    version           TEXT NOT NULL DEFAULT '',
    release_date      TEXT NOT NULL DEFAULT '',
    release_timestamp INTEGER NOT NULL DEFAULT 0,
    developer         TEXT NOT NULL DEFAULT '',
    license           TEXT NOT NULL DEFAULT '',
    homepage          TEXT NOT NULL DEFAULT '',
    bugtracker_url    TEXT NOT NULL DEFAULT '',
    donation_url      TEXT NOT NULL DEFAULT '',
    categories        TEXT NOT NULL DEFAULT '[]',
    keywords          TEXT NOT NULL DEFAULT '[]',
    icon_name         TEXT NOT NULL DEFAULT '',
    screenshots       TEXT NOT NULL DEFAULT '[]',
    content_rating    TEXT NOT NULL DEFAULT '',
    flatpak_ref       TEXT NOT NULL DEFAULT '',
    releases_json     TEXT NOT NULL DEFAULT '[]',
    verified          INTEGER NOT NULL DEFAULT 0,
    monthly_downloads INTEGER NOT NULL DEFAULT 0,
    icon_local_path   TEXT NOT NULL DEFAULT ''
);
CREATE TABLE IF NOT EXISTS nix_packages (
    attr TEXT PRIMARY KEY, pname TEXT NOT NULL,
    version TEXT NOT NULL DEFAULT '', description TEXT NOT NULL DEFAULT '',
    long_description TEXT NOT NULL DEFAULT '', homepage TEXT NOT NULL DEFAULT '',
    license TEXT NOT NULL DEFAULT '', maintainers TEXT NOT NULL DEFAULT '[]'
);
CREATE TABLE IF NOT EXISTS catalog_meta (
    source TEXT PRIMARY KEY, updated_at TEXT NOT NULL, row_count INTEGER NOT NULL DEFAULT 0
);
CREATE VIRTUAL TABLE IF NOT EXISTS catalog_fts USING fts5(
    source, id, name, description, developer, categories,
    tokenize = 'unicode61 remove_diacritics 1'
);
CREATE TABLE IF NOT EXISTS app_map (
    slug TEXT PRIMARY KEY, flatpak_id TEXT, nix_attr TEXT,
    display_name TEXT NOT NULL DEFAULT ''
);
CREATE INDEX IF NOT EXISTS idx_app_map_flatpak ON app_map(flatpak_id);
CREATE INDEX IF NOT EXISTS idx_app_map_nix     ON app_map(nix_attr);
""")

for col_def in [
    "ALTER TABLE flatpak_apps ADD COLUMN icon_local_path TEXT NOT NULL DEFAULT ''",
    "ALTER TABLE nix_packages ADD COLUMN long_description TEXT NOT NULL DEFAULT ''",
    "ALTER TABLE nix_packages ADD COLUMN maintainers TEXT NOT NULL DEFAULT '[]'",
]:
    try:
        conn.execute(col_def)
    except Exception:
        pass

now = datetime.now(tz=timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
with conn:
    conn.execute("DELETE FROM flatpak_apps")
    conn.executemany("INSERT OR REPLACE INTO flatpak_apps VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)", rows)
    conn.execute("DELETE FROM catalog_fts WHERE source='flatpak'")
    conn.executemany("INSERT INTO catalog_fts(source,id,name,description,developer,categories) VALUES (?,?,?,?,?,?)", fts_rows)
    conn.execute("INSERT OR REPLACE INTO catalog_meta(source,updated_at,row_count) VALUES ('flatpak',?,?)", (now, len(rows)))
conn.close()

icons_needed  = len(remote_icons)
ss_needed     = len(remote_screenshots)
print(f"Flatpak catalog updated: {len(rows)} apps indexed. "
      f"Icons missing: {icons_needed}. Apps needing screenshot downloads: {ss_needed}.", flush=True)

# Write pending download lists for Phase 2
import json as _json
pending_file = os.path.join(media_dir, '.pending_downloads.json')
with open(pending_file, 'w') as f:
    _json.dump({'icons': remote_icons, 'screenshots': remote_screenshots}, f)
PYEOF
    local rc=$?
    if [ $rc -ne 0 ]; then
        log "Flatpak catalog update (Phase 1) failed (exit $rc)."
        return $rc
    fi
    log "Flatpak catalog updated successfully (Phase 1 complete)."
}

# Phase 2: download missing icons and screenshots (network, can be slow on first run)
cache_flatpak_media() {
    local pending_file="$MEDIA_DIR/.pending_downloads.json"
    if [ ! -f "$pending_file" ]; then
        log "No pending media downloads."
        return 0
    fi

    log "Caching Flatpak media (Phase 2: downloading missing icons and screenshots)..."

    python3 - "$CATALOG_DB" "$MEDIA_DIR" << 'PYEOF'
import sys, os, json, sqlite3, time
import urllib.request

db_path    = sys.argv[1]
media_dir  = sys.argv[2]
icons_dir  = os.path.join(media_dir, 'icons')
ss_base_dir = os.path.join(media_dir, 'screenshots')
pending_file = os.path.join(media_dir, '.pending_downloads.json')

with open(pending_file) as f:
    pending = json.load(f)

remote_icons       = pending.get('icons', [])
remote_screenshots = pending.get('screenshots', [])

UA = {'User-Agent': 'mirror-catalog-update/1.0'}
ICON_TIMEOUT = 8
SS_TIMEOUT   = 10
# Total wall-clock budget for all media downloads (30 min)
TOTAL_BUDGET = 1800
t_start = time.monotonic()

def budget_remaining():
    return TOTAL_BUDGET - (time.monotonic() - t_start)

def fetch(url, timeout):
    req = urllib.request.Request(url, headers=UA)
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return r.read()

# ── Icons ─────────────────────────────────────────────────────────────────
icon_updates = []  # (icon_local_path, app_id)
n_icons = len(remote_icons)
print(f"Downloading {n_icons} missing icons...", flush=True)
for i, (app_id, url) in enumerate(remote_icons):
    if budget_remaining() <= 0:
        print(f"  Budget exhausted after {i} icons; deferring rest.", flush=True)
        break
    if i > 0 and i % 50 == 0:
        print(f"  Icons: {i}/{n_icons} ({time.monotonic()-t_start:.0f}s elapsed)...", flush=True)
    dst = os.path.join(icons_dir, f'{app_id}.png')
    if os.path.isfile(dst) and os.path.getsize(dst) > 0:
        icon_updates.append((dst, app_id))
        continue
    try:
        data = fetch(url, ICON_TIMEOUT)
        if data:
            with open(dst, 'wb') as f:
                f.write(data)
            icon_updates.append((dst, app_id))
    except Exception:
        pass

# ── Screenshots ───────────────────────────────────────────────────────────
ss_updates = {}  # app_id -> screenshots JSON
n_apps = len(remote_screenshots)
n_done = 0
print(f"Downloading screenshots for {n_apps} apps...", flush=True)
for app_id, screenshots_raw in remote_screenshots:
    if budget_remaining() <= 0:
        print(f"  Budget exhausted after {n_done}/{n_apps} apps; deferring rest.", flush=True)
        break
    n_done += 1
    if n_done % 100 == 0:
        print(f"  Screenshots: {n_done}/{n_apps} apps ({time.monotonic()-t_start:.0f}s elapsed)...", flush=True)

    ss_dir = os.path.join(ss_base_dir, app_id)
    os.makedirs(ss_dir, exist_ok=True)
    screenshots = []
    for i, ss in enumerate(screenshots_raw):
        local_path = os.path.join(ss_dir, f'{i}.jpg')
        if os.path.isfile(local_path) and os.path.getsize(local_path) > 0:
            screenshots.append(dict(ss, local_path=local_path))
            continue
        try:
            data = fetch(ss['url'], SS_TIMEOUT)
            if data:
                with open(local_path, 'wb') as f:
                    f.write(data)
                screenshots.append(dict(ss, local_path=local_path))
                continue
        except Exception:
            pass
        screenshots.append(dict(ss, local_path=''))
    ss_updates[app_id] = json.dumps(screenshots)

# ── Write updates back to DB ──────────────────────────────────────────────
if icon_updates or ss_updates:
    conn = sqlite3.connect(db_path, timeout=30)
    with conn:
        for local_path, app_id in icon_updates:
            conn.execute("UPDATE flatpak_apps SET icon_local_path=? WHERE app_id=?", (local_path, app_id))
        for app_id, ss_json in ss_updates.items():
            conn.execute("UPDATE flatpak_apps SET screenshots=? WHERE app_id=?", (ss_json, app_id))
    conn.close()

os.remove(pending_file)
elapsed = time.monotonic() - t_start
print(f"Phase 2 complete: {len(icon_updates)} icons, {len(ss_updates)} apps with screenshots "
      f"updated in {elapsed:.1f}s.", flush=True)
PYEOF
    local rc=$?
    if [ $rc -eq 0 ]; then
        log "Flatpak media cache updated (Phase 2 complete)."
    else
        log "Flatpak media cache update failed (exit $rc)."
    fi
}

# ── Nix catalog update ───────────────────────────────────────────────────────

update_nix() {
    log "Updating Nix catalog from nixpkgs (this may be slow on first run)..."

    if ! command -v nix &>/dev/null; then
        log "Nix not available — skipping Nix catalog update."
        return 1
    fi

    log "nix path: $(command -v nix); version: $(nix --version 2>&1 | head -1)"

    # Write output to a temp file — avoids shell variable size limits for
    # large JSON (nixpkgs has 100k+ packages) and lets us capture stderr
    # separately for diagnostics.
    local tmp_out tmp_err
    tmp_out=$(mktemp /tmp/mirror-nix-search.XXXXXX.json)
    tmp_err=$(mktemp /tmp/mirror-nix-search.XXXXXX.err)

    # ".*" matches all packages; empty string "" matches nothing in nix search regex
    log "Running: nix search nixpkgs '.*' --json ..."
    nix search nixpkgs ".*" --json > "$tmp_out" 2>"$tmp_err"
    local nix_exit=$?

    local nix_out_size
    nix_out_size=$(stat -c%s "$tmp_out" 2>/dev/null || echo 0)

    if [ -s "$tmp_err" ]; then
        log "nix search stderr (first 20 lines):"
        head -20 "$tmp_err" >> "$LOG_FILE"
    fi

    log "nix search exit=$nix_exit; stdout size=${nix_out_size} bytes"

    if [ "$nix_exit" -ne 0 ] || [ "$nix_out_size" -eq 0 ]; then
        log "nix search nixpkgs failed or returned empty output — preserving existing Nix catalog rows."
        rm -f "$tmp_out" "$tmp_err"
        return 1
    fi

    python3 - "$CATALOG_DB" "$tmp_out" << 'PYEOF'
import sys, json, sqlite3
from datetime import datetime, timezone

db_path  = sys.argv[1]
json_file = sys.argv[2]

try:
    with open(json_file) as f:
        data = json.load(f)
except Exception as e:
    print(f"mirror-catalog-update: failed to parse nix search JSON: {e}", file=sys.stderr)
    sys.exit(1)

# When multiple nix paths share the same last component (e.g. both
# legacyPackages.x86_64-linux.spotify and
# legacyPackages.x86_64-linux.homeassistantCustomComponents.spotify),
# keep only the shallowest one (fewest dots = top-level package).
best = {}  # attr -> (depth, val)
for key, val in data.items():
    attr  = key.split('.')[-1] if '.' in key else key
    depth = key.count('.')
    if attr not in best or depth < best[attr][0]:
        best[attr] = (depth, val)

rows     = []
fts_rows = []
for attr, (_, val) in best.items():
    pname = val.get('pname', attr)
    ver   = val.get('version', '')
    desc  = val.get('description', '').replace('\n', ' ').strip()
    meta  = val.get('meta', {}) if isinstance(val.get('meta'), dict) else {}
    homepage = meta.get('homepage', val.get('homepage', ''))
    if isinstance(homepage, list):
        homepage = homepage[0] if homepage else ''
    lic_raw = meta.get('license', '')
    if isinstance(lic_raw, dict):
        license_ = lic_raw.get('spdxId', lic_raw.get('fullName', ''))
    elif isinstance(lic_raw, list) and lic_raw:
        first = lic_raw[0]
        license_ = first.get('spdxId', first.get('fullName', '')) if isinstance(first, dict) else str(first)
    else:
        license_ = str(lic_raw) if lic_raw else ''

    rows.append((attr, pname, ver, desc, '', homepage, license_, '[]'))
    fts_rows.append(('nix', attr, pname, desc[:200], '', ''))

conn = sqlite3.connect(db_path, timeout=30)

# Ensure schema exists (in case only nix runs first)
conn.executescript("""
PRAGMA journal_mode=WAL;
PRAGMA synchronous=NORMAL;

CREATE TABLE IF NOT EXISTS flatpak_apps (
    app_id TEXT PRIMARY KEY, name TEXT NOT NULL DEFAULT '', summary TEXT NOT NULL DEFAULT '',
    description TEXT NOT NULL DEFAULT '', version TEXT NOT NULL DEFAULT '',
