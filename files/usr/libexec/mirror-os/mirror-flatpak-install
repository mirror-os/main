#!/usr/bin/env bash
# Mirror OS Flatpak Reconciler
# Runs on every boot via mirror-os-flatpak-init.service as root.
#
# managed-apps.list  — installed if missing; removed if deleted from the list
# pinned-apps.list   — installed if missing; never removed by image updates
#
# Only system-scope Flatpaks are managed. User-scope installs are untouched.

set -uo pipefail

MANAGED_LIST="/usr/share/mirror-os/managed-apps.list"
PINNED_LIST="/usr/share/mirror-os/pinned-apps.list"
LOG="/var/log/mirror-os-flatpak.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"
    if [ -f "$LOG" ] && [ "$(stat -c%s "$LOG" 2>/dev/null || echo 0)" -gt 1048576 ]; then
        mv "$LOG" "${LOG}.1"
        touch "$LOG"
    fi
}

mkdir -p /var/lib/mirror-os

# ── Load lists into associative arrays ──────────────────────────────────────
declare -A managed=()
declare -A pinned=()

read_list() {
    local file="$1"
    local -n ref="$2"
    [ -f "$file" ] || return
    while IFS= read -r appid; do
        [[ -z "$appid" || "$appid" == \#* ]] && continue
        ref["$appid"]=1
    done < "$file"
}

read_list "$MANAGED_LIST" managed
read_list "$PINNED_LIST" pinned

log "=== Mirror OS Flatpak reconciliation starting ==="
log "Managed: ${!managed[*]:-none}"
log "Pinned:  ${!pinned[*]:-none}"

# ── Get current system-scope installs ───────────────────────────────────────
mapfile -t installed < <(flatpak list --system --app --columns=application 2>/dev/null)

# ── Install missing apps from both lists ────────────────────────────────────
all_wanted=("${!managed[@]}" "${!pinned[@]}")
for appid in "${all_wanted[@]}"; do
    if printf '%s\n' "${installed[@]}" | grep -qx "$appid"; then
        log "Already installed: $appid"
    else
        log "Installing: $appid"
        flatpak install --system --noninteractive flathub "$appid" 2>&1 | tee -a "$LOG" || \
            log "WARNING: Could not install $appid"
    fi
done

# ── Remove system-scope apps no longer in either list ───────────────────────
for appid in "${installed[@]}"; do
    [[ -n "${managed[$appid]+x}" || -n "${pinned[$appid]+x}" ]] && continue
    log "Removing (no longer managed): $appid"
    flatpak uninstall --system --noninteractive "$appid" 2>&1 | tee -a "$LOG" || \
        log "WARNING: Could not remove $appid"
done

log "=== Mirror OS Flatpak reconciliation complete ==="
