#!/usr/bin/env bash
# mirror-os — Mirror OS declarative app manager
# Manages apps by creating/removing .nix modules in ~/.config/home-manager/apps/.
# Supports Flatpak (preferred) and Nix packages; pro flakes via --flake.
#
# Usage:
#   mirror-os install <query> [--flatpak | --nix] [--pick]
#   mirror-os install --flake <url> <name>
#   mirror-os uninstall <id>
#   mirror-os search <query> [--json]
#   mirror-os browse [--source flatpak|nix|all] [--category <cat>] [--limit N] [--json]
#   mirror-os list [--json]
#   mirror-os info <id> [--json]
#   mirror-os rename <id> <label>
#   mirror-os instances <slug> [--json]
#   mirror-os update
#   mirror-os catalog update|status
#   mirror-os snapshots [--type cosmic|apps|all] [--json]
#   mirror-os rollback cosmic <sha|index>
#   mirror-os system update
#   mirror-os --app <id> --add-option <key> <value>
#   mirror-os --app <id> --remove-option <key>
#   mirror-os --app <id> --show-config
#   mirror-os --app <id> --edit

set -uo pipefail

export PATH="/nix/var/nix/profiles/default/bin:$HOME/.nix-profile/bin:$PATH"

# ── Constants ────────────────────────────────────────────────────────────────

APPS_DIR="$HOME/.config/home-manager/apps"
HM_CONFIG_DIR="$HOME/.config/home-manager"
FLAKE_NIX="$HM_CONFIG_DIR/flake.nix"
CATALOG_DB="$HOME/.local/share/mirror-os/catalog.db"
INSTANCES_DB="$HOME/.local/share/mirror-os/instances.db"
LOG_FILE="$HOME/.local/share/mirror-os/mirror-os.log"
VERBOSE_LOG=false

# ── Load libraries ───────────────────────────────────────────────────────────

_LIB="/usr/libexec/mirror-os/lib"
# shellcheck source=lib/core.bash
source "$_LIB/core.bash"
# shellcheck source=lib/catalog.bash
source "$_LIB/catalog.bash"
# shellcheck source=lib/modules.bash
source "$_LIB/modules.bash"
# shellcheck source=lib/instances.bash
source "$_LIB/instances.bash"
# shellcheck source=lib/cmd-install.bash
source "$_LIB/cmd-install.bash"
# shellcheck source=lib/cmd-search.bash
source "$_LIB/cmd-search.bash"
# shellcheck source=lib/cmd-info.bash
source "$_LIB/cmd-info.bash"
# shellcheck source=lib/cmd-hm.bash
source "$_LIB/cmd-hm.bash"
# shellcheck source=lib/cmd-system.bash
source "$_LIB/cmd-system.bash"

# ── Usage ────────────────────────────────────────────────────────────────────

usage() {
    cat << 'EOF'
mirror-os — Mirror OS declarative app manager

Usage:
  mirror-os install <query>                        Search Flatpak + Nix, auto-select best
  mirror-os install <query> --pick                 Search and pick interactively
  mirror-os install <query> --flatpak              Flatpak only: exact ID if known, else search
  mirror-os install <query> --nix                  Nix only: exact attr if known, else search
  mirror-os install <query> --flatpak [--name <n>] Same with display name override
  mirror-os install --flake <url> <name>           Install a pro flake app config
  mirror-os uninstall <query>                      Remove an installed app
  mirror-os search <query> [--json]                Search without installing
  mirror-os browse [--source flatpak|nix|all]      Browse all apps
             [--category <cat>] [--limit N] [--json]
  mirror-os list [--json]                          List mirror-os managed apps
  mirror-os info <id> [--json]                     Show app details and module
  mirror-os rename <id> <label>                    Set a display label for an installed app
  mirror-os instances <slug> [--json]              Show all instances of an app (cross-source)
  mirror-os update                                 Update flake.lock and switch
  mirror-os catalog update [--source flatpak|nix|all]  Rebuild app catalog DB
  mirror-os catalog status                         Show catalog build status
  mirror-os snapshots [--type cosmic|apps|all] [--json]  List state snapshots
  mirror-os rollback cosmic <sha|index>            Restore COSMIC config from snapshot
  mirror-os system update                          Stage the latest OS image update

  mirror-os --app <id> --add-option <key> <value>  Add a Nix option to an app
  mirror-os --app <id> --remove-option <key>        Remove a Nix option from an app
  mirror-os --app <id> --show-config               Print the app's .nix module
  mirror-os --app <id> --edit                      Open the app's .nix in $EDITOR

Global flags (work with any command):
  --log                                            Print diagnostic log output to the terminal

Examples:
  mirror-os install spotify
  mirror-os install spotify --pick
  mirror-os install ripgrep --nix
  mirror-os install --flake github:mirror-os/apps#devtools devtools
  mirror-os install com.spotify.Client --flatpak
  mirror-os install com.spotify.Client --flatpak --name "Spotify"
  mirror-os install spotify --nix
  mirror-os uninstall spotify
  mirror-os info com.spotify.Client
  mirror-os info com.spotify.Client --json
  mirror-os list --json
  mirror-os search vscode --json
  mirror-os browse --category Audio --json
  mirror-os catalog update
  mirror-os catalog status
  mirror-os --app com.spotify.Client --add-option "environment.PULSE_LATENCY_MSEC" "60"
  mirror-os --app com.spotify.Client --remove-option "environment.PULSE_LATENCY_MSEC"
  mirror-os --app com.spotify.Client --edit
  mirror-os snapshots --type cosmic
  mirror-os snapshots --json
  mirror-os rollback cosmic 2
  mirror-os system update
EOF
}

# ── Dispatcher ───────────────────────────────────────────────────────────────

# Strip --log from args and set VERBOSE_LOG before dispatching
_args=()
for _arg in "$@"; do
    [ "$_arg" = "--log" ] && VERBOSE_LOG=true || _args+=("$_arg")
done
set -- "${_args[@]+"${_args[@]}"}"
unset _arg _args

log "CMD: ${*}${VERBOSE_LOG:+ [--log]}"

case "${1:-}" in
    install)   shift; cmd_install "$@" ;;
    uninstall) shift; cmd_uninstall "$@" ;;
    rename)    shift; cmd_rename "$@" ;;
    instances) shift; cmd_instances "$@" ;;
    search)    shift; cmd_search "$@" ;;
    browse)    shift; cmd_browse "$@" ;;
    list)      shift; cmd_list "$@" ;;
    info)      shift; cmd_info "$@" ;;
    update)    cmd_update ;;
    catalog)   shift; cmd_catalog "$@" ;;
    snapshots) shift; cmd_snapshots "$@" ;;
    rollback)  shift; cmd_rollback "$@" ;;
    system)    shift; cmd_system "$@" ;;
    --app)
        shift
        app_id="${1:-}"; shift
        case "${1:-}" in
            --add-option)
                shift; cmd_add_option "$app_id" "$@" ;;
            --remove-option)
                shift; cmd_remove_option "$app_id" "$@" ;;
            --show-config)
                need_init
                f=$(module_file "$app_id")
                [ -f "$f" ] || die "App '${app_id}' not found. Use 'mirror-os list'."
                cat "$f" ;;
            --edit)
                need_init
                f=$(module_file "$app_id")
                [ -f "$f" ] || die "App '${app_id}' not found. Use 'mirror-os list'."
                ${EDITOR:-nano} "$f"
                trigger_switch "mirror-os: edit ${app_id}" ;;
            *) die "Unknown option for --app: ${1:-}. Options: --add-option, --remove-option, --show-config, --edit" ;;
        esac
        ;;
    help|--help|-h) usage ;;
    "")             usage; exit 1 ;;
    *)              die "Unknown command: $1. Run 'mirror-os help' for usage." ;;
esac
