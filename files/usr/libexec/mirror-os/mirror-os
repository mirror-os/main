        local _origin
        _origin=$(grep -o 'origin\s*=\s*"[^"]*"' "$out_file" 2>/dev/null \
                  | sed 's/.*"\([^"]*\)".*/\1/' | head -1)
        src="${_origin^}"
        [ -z "$src" ] && src="Flatpak"
    fi
