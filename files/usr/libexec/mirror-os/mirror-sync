#!/usr/bin/env bash
# Mirror OS State Sync
# Runs at boot and every :00 hourly.
# Tracks app installs/removals, syncs app settings via gitallow, versions everything with git.

set -uo pipefail

export PATH="/nix/var/nix/profiles/default/bin:$HOME/.nix-profile/bin:$PATH"

LOG="$HOME/.local/share/mirror-os/sync.log"
STATE_DIR="$HOME/.local/share/mirror-os/state"
HM_CONFIG_DIR="$HOME/.config/home-manager"
INIT_DONE="$HOME/.local/share/mirror-os/.init-complete"
ALLOWLIST="/usr/share/mirror-os/flatpak-allowlist.toml"
SETTINGS_SNAPSHOT_DIR="$STATE_DIR/flatpak-settings"
FLATPAK_DATA_DIR="$HOME/.var/app"

mkdir -p "$STATE_DIR" "$(dirname "$LOG")"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"
    if [ -f "$LOG" ] && [ "$(stat -c%s "$LOG" 2>/dev/null || echo 0)" -gt 1048576 ]; then
        mv "$LOG" "${LOG}.1"
        touch "$LOG"
    fi
}

# ── Guards ─────────────────────────────────────────────────────────────────
if [ ! -f "$INIT_DONE" ]; then
    log "Init not yet complete, skipping sync"
    exit 0
fi

if ! command -v nix &>/dev/null; then
    log "Nix not found, skipping sync"
    exit 0
fi

# ── Refresh catalog from image if updated ────────────────────────────────────
# mirror-catalog-bootstrap checks whether the system catalog.db hash has changed
# since the last run and exits immediately (<0.1 s) when nothing has changed.
# This covers the image-update case: when a new image is booted, mirror-sync
# detects the hash mismatch on its first run and refreshes catalog + icons.
if [ -f /usr/share/mirror-os/catalog.db ]; then
    /usr/libexec/mirror-os/mirror-catalog-bootstrap >> "$LOG" 2>&1 \
        || log "WARNING: catalog refresh failed (non-fatal)"
fi

log "=== Mirror OS Sync starting ==="

# ── App state snapshot ───────────────────────────────────────────────────────
# Record the current Flatpak list for git history. Default apps are installed
# once by mirror-init and never managed here.
CURRENT_APPS=$(flatpak list --app --columns=application 2>/dev/null | sort)
CHANGED=false

# ── Detect image update ──────────────────────────────────────────────────────
# Hash all image-managed mirror-os files.  When a new image is booted these
# may change; any change triggers a flake.nix refresh + home-manager switch.
SYSTEM_HM_HASH_FILE="$STATE_DIR/system-hm.hash"
SYSTEM_HM_HASH=$(sha256sum \
    /usr/share/mirror-os/home.nix \
    /usr/share/mirror-os/flake.nix.template \
    /usr/share/mirror-os/home-user.nix.template \
    2>/dev/null | sha256sum | cut -d' ' -f1 || echo "")
if [ -n "$SYSTEM_HM_HASH" ]; then
    if [ ! -f "$SYSTEM_HM_HASH_FILE" ] || \
       [ "$SYSTEM_HM_HASH" != "$(cat "$SYSTEM_HM_HASH_FILE")" ]; then
        log "Image mirror-os files changed (image updated) — refreshing HM config"
        echo "$SYSTEM_HM_HASH" > "$SYSTEM_HM_HASH_FILE"
        CHANGED=true
    fi
fi

# ── Refresh HM infrastructure from image templates (image updates only) ──────
# When the image updates, rewrite flake.nix from the current template so the
# user's config always tracks the image's module list and input versions.
# home-user.nix is NEVER overwritten — it belongs to the user.
# Pro flake inputs added by mirror-os are extracted from the old flake and
# re-injected into the refreshed one so they survive the update.
if [ "$CHANGED" = true ] && [ -d "$HM_CONFIG_DIR" ]; then
    FLAKE_TEMPLATE="/usr/share/mirror-os/flake.nix.template"
    FLAKE_NIX="$HM_CONFIG_DIR/flake.nix"
    MARKER="# Pro flake inputs are added here by mirror-os tool"

    if [ -f "$FLAKE_TEMPLATE" ]; then
        log "Refreshing flake.nix from image template..."

        # Extract any pro flake inputs that mirror-os injected after the marker
        PRO_INPUTS=""
        if [ -f "$FLAKE_NIX" ] && grep -q "$MARKER" "$FLAKE_NIX"; then
            PRO_INPUTS=$(awk \
                "/$MARKER/{found=1; next} found && /^  \};/{exit} found{print}" \
                "$FLAKE_NIX" 2>/dev/null || true)
        fi

        # Re-scaffold from template
        sed "s/__USERNAME__/$USER/g" "$FLAKE_TEMPLATE" > "$FLAKE_NIX"

        # Re-inject any pro flake inputs
        if [ -n "$PRO_INPUTS" ]; then
            # Escape for sed replacement
            escaped=$(printf '%s\n' "$PRO_INPUTS" | sed 's/[[\.*^$()+?{|]/\\&/g')
            sed -i "s|${MARKER}|${MARKER}\n${escaped}|" "$FLAKE_NIX"
            log "Re-injected pro flake inputs into refreshed flake.nix"
        fi

        log "flake.nix refreshed from image template"
    fi

    # Ensure home-user.nix exists (may be absent on very old setups)
    if [ ! -f "$HM_CONFIG_DIR/home-user.nix" ]; then
        USERTEMPLATE="/usr/share/mirror-os/home-user.nix.template"
        if [ -f "$USERTEMPLATE" ]; then
            sed "s/__USERNAME__/$USER/g" "$USERTEMPLATE" \
                > "$HM_CONFIG_DIR/home-user.nix"
            log "home-user.nix created from template (was missing)"
        fi
    fi

    # Ensure apps/ exists
    mkdir -p "$HM_CONFIG_DIR/apps"

    # Reconcile the flake lock: pins new inputs, removes stale ones (e.g.
    # cosmic-manager if removed from template), keeps unchanged inputs pinned.
    log "Reconciling flake.lock..."
    (cd "$HM_CONFIG_DIR" && nix flake lock >> "$LOG" 2>&1) || \
        log "WARNING: nix flake lock failed — switch may fail"

    # Stage everything (refreshed flake.nix, new flake.lock, any new files)
    git -C "$HM_CONFIG_DIR" add -A 2>/dev/null || true

    log "Running home-manager switch (image update)..."
    cd "$HM_CONFIG_DIR"
    if home-manager switch --flake ".#$USER" --impure >> "$LOG" 2>&1; then
        log "home-manager switch succeeded"
    else
        log "WARNING: home-manager switch failed"
    fi
fi

# ── Gitallow: build rsync filter rules for a given Flatpak app ─────────────
mirror_build_app_rules() {
    local app_id="$1"
    local rules_file
    rules_file=$(mktemp "/tmp/mirror-rsync-rules-XXXXXX")

    if [ ! -f "$ALLOWLIST" ]; then
        echo "- *" > "$rules_file"
        echo "$rules_file"
        return
    fi

    python3 - "$app_id" "$ALLOWLIST" "$rules_file" << 'PYEOF'
import sys
import re

app_id = sys.argv[1]
toml_path = sys.argv[2]
out_path = sys.argv[3]

def parse_allowlist(path):
    result = {'allow': [], 'deny': [], 'apps': {}}
    current_section = None
    current_app = None

    try:
        with open(path) as f:
            lines = f.readlines()
    except Exception:
        return result

    for line in lines:
        line = line.strip()
        if not line or line.startswith('#'):
            continue

        if line == '[allow]':
            current_section = 'allow'
            current_app = None
            continue
        elif line == '[deny]':
            current_section = 'deny'
            current_app = None
            continue
        elif line == '[[app]]':
            current_section = 'app'
            current_app = {}
            continue

        if current_section == 'app' and current_app is not None:
            if line.startswith('id'):
                m = re.match(r'id\s*=\s*"([^"]+)"', line)
                if m:
                    current_app['id'] = m.group(1)
                    result['apps'][m.group(1)] = current_app
            else:
                key_match = re.match(r'(\w+)\s*=\s*\[', line)
                if key_match:
                    key = key_match.group(1)
                    current_app['_collecting'] = key
                    inline = re.findall(r'"([^"]+)"', line)
                    if inline and ']' in line:
                        current_app[key] = inline
                        current_app.pop('_collecting', None)
                    else:
                        current_app.setdefault(key, [])
                        for v in inline:
                            current_app[key].append(v)
                elif current_app.get('_collecting'):
                    if ']' in line:
                        current_app.pop('_collecting', None)
                    else:
                        m = re.match(r'"([^"]+)"', line)
                        if m:
                            key = current_app['_collecting']
                            current_app.setdefault(key, []).append(m.group(1))

        elif current_section in ('allow', 'deny'):
            m = re.match(r'"([^"]+)"', line)
            if m:
                result[current_section].append(m.group(1))

    return result

def glob_to_rsync(pattern):
    p = pattern.lstrip('/')
    if p.startswith('**/'):
        p = p[3:]
    if p.endswith('/**'):
        p = p[:-3] + '/'
    return p

data = parse_allowlist(toml_path)
app_data = data['apps'].get(app_id, {})
rules = []

if 'override_allow' in app_data:
    for p in app_data.get('override_deny', []):
        rules.append(f'- {glob_to_rsync(p)}')
    for p in app_data.get('override_allow', []):
        rules.append(f'+ {glob_to_rsync(p)}')
    rules.append('- *')
else:
    for p in app_data.get('extra_deny', []):
        rules.append(f'- {glob_to_rsync(p)}')
    for p in data['deny']:
        rules.append(f'- {glob_to_rsync(p)}')
    for p in app_data.get('extra_allow', []):
        rules.append(f'+ {glob_to_rsync(p)}')
    for p in data['allow']:
        rules.append(f'+ {glob_to_rsync(p)}')
    rules.append('- *')

with open(out_path, 'w') as f:
    for r in rules:
        f.write(r + '\n')
PYEOF

    echo "$rules_file"
}

# ── Sync app settings via gitallow ─────────────────────────────────────────
sync_flatpak_settings() {
    [ ! -d "$FLATPAK_DATA_DIR" ] && return
    if [ ! -f "$ALLOWLIST" ]; then
        log "WARNING: No flatpak-allowlist.toml found, skipping app settings sync"
        return
    fi

    log "Syncing app settings (gitallow)..."
    mkdir -p "$SETTINGS_SNAPSHOT_DIR"

    for app_dir in "$FLATPAK_DATA_DIR"/*/; do
        local app_id
        app_id=$(basename "$app_dir")
        [ ! -d "$app_dir" ] && continue

        local snapshot_dir="$SETTINGS_SNAPSHOT_DIR/$app_id"
        local rules_file
        rules_file=$(mirror_build_app_rules "$app_id")

        mkdir -p "$snapshot_dir"

        rsync -a --delete \
            --filter="merge $rules_file" \
            "$app_dir" \
            "$snapshot_dir/" \
            2>/dev/null || log "WARNING: rsync failed for $app_id"

        rm -f "$rules_file"
    done
}

# ── State snapshot ──────────────────────────────────────────────────────────
echo "$CURRENT_APPS" > "$STATE_DIR/flatpak-apps.list"
flatpak list --app --columns=application,version,branch 2>/dev/null > \
    "$STATE_DIR/flatpak-full.list"

mkdir -p "$STATE_DIR/home-manager"
cp -r "$HM_CONFIG_DIR/." "$STATE_DIR/home-manager/" 2>/dev/null || true

if [ -d "$HOME/.config/cosmic" ]; then
    mkdir -p "$STATE_DIR/cosmic-config"
    rsync -a --delete "$HOME/.config/cosmic/" "$STATE_DIR/cosmic-config/" 2>/dev/null || \
        cp -r "$HOME/.config/cosmic/." "$STATE_DIR/cosmic-config/" 2>/dev/null || true
fi

nix profile list > "$STATE_DIR/nix-profile.list" 2>/dev/null || true

sync_flatpak_settings

# ── Git commit ──────────────────────────────────────────────────────────────
cd "$STATE_DIR"
if [ -n "$(git status --short 2>/dev/null)" ]; then
    # Detect COSMIC config changes before staging so we can diff against HEAD.
    COSMIC_CHANGED_COUNT=$(git diff --name-only 2>/dev/null \
        | grep -c "^cosmic-config/" || true)

    # Write a human-readable summary of which COSMIC components changed.
    # The Software Center reads this file from git history for its rollback UI.
    if [ "${COSMIC_CHANGED_COUNT:-0}" -gt 0 ]; then
        git diff --name-only 2>/dev/null \
            | grep "^cosmic-config/" \
            | sed 's|cosmic-config/||' \
            | sort > "$STATE_DIR/cosmic-changes.log"
        log "COSMIC config changed: $COSMIC_CHANGED_COUNT file(s)"
    fi

    git add -A

    CHANGED_APPS=$(git diff --cached --name-only 2>/dev/null \
        | grep "^flatpak-settings/" \
        | sed 's|flatpak-settings/||' \
        | cut -d'/' -f1 \
        | sort -u | tr '\n' ' ')

    COMMIT_MSG="sync: $(date '+%Y-%m-%d %H:%M:%S')"
    [ -n "$CHANGED_APPS" ] && COMMIT_MSG="$COMMIT_MSG | settings: $CHANGED_APPS"
    [ "${COSMIC_CHANGED_COUNT:-0}" -gt 0 ] && \
        COMMIT_MSG="$COMMIT_MSG | cosmic: ${COSMIC_CHANGED_COUNT} file(s)"
    [ "$CHANGED" = true ] && COMMIT_MSG="$COMMIT_MSG | apps updated"

    git commit -m "$COMMIT_MSG" >> "$LOG" 2>&1 && \
        log "State committed: $COMMIT_MSG" || \
        log "WARNING: git commit failed"
else
    log "No state changes to commit"
fi

log "=== Mirror OS Sync complete ==="
