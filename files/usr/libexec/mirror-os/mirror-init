#!/usr/bin/env bash
# Mirror OS First-Boot Initializer
# Installs Nix, scaffolds Home Manager, runs first home-manager switch, and
# initialises the state git repo.
# Default Flatpak apps are installed by mirror-os-flatpak-init.service (a
# system service that runs before the display manager on first boot).

set -uo pipefail

LOG="/var/home/$USER/.local/share/mirror-os/init.log"
DONE_MARKER="/var/home/$USER/.local/share/mirror-os/.init-complete"
HM_CONFIG_DIR="/var/home/$USER/.config/home-manager"
STATE_DIR="/var/home/$USER/.local/share/mirror-os/state"
TEMPLATES_DIR="/usr/share/mirror-os"

mkdir -p "$(dirname "$LOG")" "$STATE_DIR"

# Bring Nix into PATH if it is already installed.
# Without this, 'command -v nix' fails in the minimal PATH of a systemd user
# service, causing mirror-init to attempt a reinstall on every re-run after
# mirror-dev-reset --init.  The Determinate Systems installer refuses to run
# when Nix is already present, which triggers die "Nix installation failed".
if [ -x /nix/var/nix/profiles/default/bin/nix ]; then
    export PATH="/nix/var/nix/profiles/default/bin:$HOME/.nix-profile/bin:$PATH"
fi

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"
    if [ -f "$LOG" ] && [ "$(stat -c%s "$LOG" 2>/dev/null || echo 0)" -gt 1048576 ]; then
        mv "$LOG" "${LOG}.1"
        touch "$LOG"
    fi
}

die() {
    log "ERROR: $*"
    notify "Mirror OS setup failed" "Check the log at ~/.local/share/mirror-os/init.log" "dialog-error"
    exit 1
}

# notify-send wrapper — works from a systemd user service via the session bus
notify() {
    local summary="$1" body="$2" icon="${3:-dialog-information}"
    DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus" \
        notify-send -a "Mirror OS" -u normal -i "$icon" "$summary" "$body" 2>/dev/null || true
}

log "=== Mirror OS Init starting (user: $USER) ==="

# ── Step 1: Guard — already done ───────────────────────────────────────────
if [ -f "$DONE_MARKER" ]; then
    log "Init already completed. Exiting."
    exit 0
fi

notify "Setting up Mirror OS…" "First-time setup is running in the background. This may take a few minutes." "system-software-install"

# ── Step 2: Set default hostname ───────────────────────────────────────────
# Set hostname to "mirror-os" on first boot if no static hostname is configured.
# Without this, systemd picks up the IPv6 RDNS from DHCPv6 and sets a transient
# hostname like "dynamic-2a02-…" which persists across the session.
if [ -z "$(cat /etc/hostname 2>/dev/null | tr -d '[:space:]')" ]; then
    log "Setting hostname to mirror-os..."
    if sudo /usr/bin/hostnamectl set-hostname mirror-os; then
        log "Hostname set to mirror-os"
    else
        log "WARNING: Could not set hostname — run manually: sudo hostnamectl set-hostname mirror-os"
    fi
else
    log "Hostname already set: $(cat /etc/hostname)"
fi

# ── Step 4: Set zsh as the default login shell ─────────────────────────────
# /usr/bin/zsh is baked into the image.  The sudoers drop-in at
# /etc/sudoers.d/mirror-os-chsh grants passwordless usermod -s for wheel
# users so this runs non-interactively inside the user service.
ZSH_BIN="/usr/bin/zsh"
CURRENT_SHELL=$(getent passwd "$USER" | cut -d: -f7)
if [ "$CURRENT_SHELL" != "$ZSH_BIN" ]; then
    log "Setting default shell to zsh..."
    if sudo /usr/sbin/usermod -s "$ZSH_BIN" "$USER"; then
        log "Default shell set to $ZSH_BIN"
    else
        log "WARNING: Could not set default shell — run manually: sudo usermod -s /usr/bin/zsh $USER"
    fi
else
    log "Default shell is already zsh"
fi

# ── Step 5: Install Nix if missing ─────────────────────────────────────────
if ! command -v nix &>/dev/null; then
    log "Installing Nix (Determinate Systems)..."
    notify "Installing Nix…" "Downloading the Nix package manager. This is the longest step." "system-software-install"
    # Run the installer as root via a dedicated wrapper script.
    # mirror-init runs as a user service with no terminal, so we cannot use an
    # interactive sudo prompt.  The sudoers drop-in at
    # /etc/sudoers.d/mirror-os-nix-install grants passwordless sudo for this
    # specific script only.
    sudo /usr/libexec/mirror-os/mirror-nix-install >> "$LOG" 2>&1 || die "Nix installation failed"

    # shellcheck disable=SC1091
    . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
    log "Nix installed successfully"
else
    log "Nix already installed"
    export PATH="/nix/var/nix/profiles/default/bin:$HOME/.nix-profile/bin:$PATH"
fi

# Wait for nix daemon
for i in $(seq 1 30); do
    nix store info &>/dev/null && break
    log "Waiting for nix daemon... ($i/30)"
    sleep 2
done
nix store info &>/dev/null || die "Nix daemon not responding after 60s"

# ── Step 6: Pre-populate COSMIC config from system defaults ────────────────
# mirror-os-init now starts after graphical-session.target so COSMIC is
# already running; this guard still protects against missing config on any
# re-run (e.g. after mirror-dev-reset --cosmic).
if [ ! -d "/var/home/$USER/.config/cosmic" ]; then
    log "Initialising COSMIC config from system defaults..."
    cp -r /usr/share/cosmic "/var/home/$USER/.config/cosmic"
    log "COSMIC config initialised"
fi

# ── Step 7: Set global git identity ────────────────────────────────────────
# Ensures git commits (state repo, home-manager repo) work without user
# interaction. Only set if the user has not already configured git.
if [ -z "$(git config --global user.email 2>/dev/null)" ]; then
    git config --global user.name "$USER"
    git config --global user.email "$USER@mirror-os.local"
    log "Set global git identity: $USER <$USER@mirror-os.local>"
fi

# ── Step 8: Scaffold home-manager config ───────────────────────────────────
# home.nix is NOT scaffolded — it lives read-only at /usr/share/mirror-os/home.nix
# and is imported directly by flake.nix.  Only flake.nix and home-user.nix are
# user-owned files that need to be scaffolded once.
if [ ! -d "$HM_CONFIG_DIR" ]; then
    log "Scaffolding home-manager config..."
    mkdir -p "$HM_CONFIG_DIR/apps"

    for template in flake.nix home-user.nix; do
        sed "s/__USERNAME__/$USER/g" \
            "$TEMPLATES_DIR/${template}.template" \
            > "$HM_CONFIG_DIR/$template"
    done

    log "home-manager config scaffolded at $HM_CONFIG_DIR"
else
    log "home-manager config already exists, skipping scaffold"
    # Ensure apps/ directory exists (in case of upgrade from older image)
    mkdir -p "$HM_CONFIG_DIR/apps"
fi

# ── Step 9: Ensure HM config dir is a git repo with all files tracked ──────
# Nix flake evaluation only sees files that git knows about (committed or
# staged). If the directory is not a repo yet, or files were generated without
# being staged, the switch at step 8 would fail with "path does not exist in
# Git repository".
if [ ! -d "$HM_CONFIG_DIR/.git" ]; then
    git -C "$HM_CONFIG_DIR" init -b main -q
    git -C "$HM_CONFIG_DIR" config user.name "$USER"
    git -C "$HM_CONFIG_DIR" config user.email "$USER@mirror-os.local"
    log "Initialised git repo in home-manager config dir"
fi
git -C "$HM_CONFIG_DIR" add -A -q
git -C "$HM_CONFIG_DIR" \
    commit -m "init: scaffold from image templates $(date '+%Y-%m-%d')" -q \
    2>/dev/null || true

# ── Step 10: Initialise state git repo ──────────────────────────────────────
if [ ! -d "$STATE_DIR/.git" ]; then
    log "Initialising state git repository..."
    git -C "$STATE_DIR" init -q
    git -C "$STATE_DIR" config user.name "$USER"
    git -C "$STATE_DIR" config user.email "$USER@mirror-os.local"
fi

# ── Step 11: Set up user-scope Flatpak remote ───────────────────────────────
# nix-flatpak installs user-selected apps at user scope (flatpak --user).
# The system-scope flathub remote (used by managed-apps.list) is a separate
# Flatpak installation and is not available to user-scope installs.
# We must add the remote here, before the first home-manager switch, so
# nix-flatpak can find it during activation.
log "Configuring user-scope Flatpak remote..."
if flatpak remote-add --user --if-not-exists flathub \
        https://dl.flathub.org/repo/flathub.flatpakrepo >> "$LOG" 2>&1; then
    log "User-scope flathub remote configured"
else
    log "WARNING: Could not add user-scope flathub remote — user Flatpak installs may fail"
fi
if flatpak remote-add --user --if-not-exists cosmic \
        https://apt.pop-os.org/cosmic/cosmic.flatpakrepo >> "$LOG" 2>&1; then
    log "User-scope cosmic remote configured"
else
    log "WARNING: Could not add user-scope cosmic remote — COSMIC apps may not show in Software Center"
fi

# ── Step 11b: Bootstrap catalog database ────────────────────────────────────
# Downloads a pre-built catalog.db and media archives from the catalog-data
# GitHub release so the Software Center is populated immediately, without
# waiting for mirror-os-catalog.timer to build the DB from scratch (30+ min).
# Non-fatal: failures are logged and mirror-init continues normally.
log "Bootstrapping catalog database from pre-built release..."
notify "Preparing app catalog…" "Downloading the app catalog for Mirror OS Software Center." "system-software-install"
/usr/libexec/mirror-os/mirror-catalog-bootstrap >> "$LOG" 2>&1 \
    || log "WARNING: catalog bootstrap failed — catalog will build on next timer run."

# ── Step 12: First home-manager switch ─────────────────────────────────────
# nix-flatpak applies global Flatpak overrides (GTK/icon theme) as part of
# this switch. Default apps are managed by mirror-os-flatpak-init.service, not nix-flatpak.
log "Running home-manager switch (first run may take a while)..."
notify "Configuring your environment…" "Setting up Home Manager. This may take a while." "system-software-install"
cd "$HM_CONFIG_DIR"

HM_CMD="nix run nixpkgs#home-manager --"

if $HM_CMD switch --flake ".#$USER" --impure >> "$LOG" 2>&1; then
    log "home-manager switch succeeded"
else
    log "WARNING: home-manager switch failed — will retry on next sync. Check $LOG"
fi

# ── Step 13: Initial state git commit ─────────────────────────────────────
mkdir -p "$STATE_DIR/home-manager"
cp -r "$HM_CONFIG_DIR/." "$STATE_DIR/home-manager/" 2>/dev/null || true
flatpak list --app --columns=application,version 2>/dev/null > "$STATE_DIR/flatpak-state.list"
flatpak list --app --columns=application 2>/dev/null | sort > "$STATE_DIR/flatpak-apps.list"

git -C "$STATE_DIR" add -A
git -C "$STATE_DIR" commit -m "init: Mirror OS first boot $(date '+%Y-%m-%d %H:%M:%S')" \
    >> "$LOG" 2>&1 || true

# ── Done ───────────────────────────────────────────────────────────────────
touch "$DONE_MARKER"
log "=== Mirror OS Init complete ==="
notify "Mirror OS is ready!" "Setup complete. Your system is fully configured." "dialog-information"
