#!/usr/bin/env bash
# mirror-catalog-bootstrap — Seed the app catalog from the image on first login.
#
# Copies the pre-built catalog.db and icons baked into the image at
# /usr/share/mirror-os/ to the user's data directory so the Software Center
# is populated immediately without waiting for mirror-catalog-update.
#
# Called from mirror-init. Only runs if catalog.db does not yet exist.
# Non-fatal: exits 0 on any error so mirror-init is never blocked.

set -uo pipefail

CATALOG_DB="$HOME/.local/share/mirror-os/catalog.db"
MEDIA_DIR="$HOME/.local/share/mirror-os/media"
LOG="$HOME/.local/share/mirror-os/catalog-bootstrap.log"
SYSTEM_CATALOG="/usr/share/mirror-os/catalog.db"
SYSTEM_ICONS="/usr/share/mirror-os/media/icons"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"; }

# ── Guard: only run on first login ────────────────────────────────────────────
if [ -f "$CATALOG_DB" ]; then
    log "catalog.db already exists — skipping bootstrap."
    exit 0
fi

if [ ! -f "$SYSTEM_CATALOG" ]; then
    log "WARNING: system catalog not found at $SYSTEM_CATALOG — skipping."
    exit 0
fi

log "=== Mirror OS catalog bootstrap starting ==="
mkdir -p "$(dirname "$CATALOG_DB")" "$MEDIA_DIR/icons" "$MEDIA_DIR/screenshots"

# ── Copy catalog.db ───────────────────────────────────────────────────────────
log "Seeding catalog.db from image..."
if ! cp "$SYSTEM_CATALOG" "$CATALOG_DB"; then
    log "WARNING: failed to copy catalog.db"
    exit 0
fi
log "catalog.db ready ($(du -sh "$CATALOG_DB" | cut -f1))"

# ── Copy icons ────────────────────────────────────────────────────────────────
if [ -d "$SYSTEM_ICONS" ] && [ "$(ls -A "$SYSTEM_ICONS" 2>/dev/null)" ]; then
    log "Seeding icons from image..."
    cp -r "$SYSTEM_ICONS/." "$MEDIA_DIR/icons/"
    ICON_COUNT=$(ls "$MEDIA_DIR/icons/"*.png 2>/dev/null | wc -l)
    log "Icons ready: $ICON_COUNT files"

    # Repopulate icon_local_path to point to the user's media directory
    python3 - "$CATALOG_DB" "$MEDIA_DIR/icons" << 'PYEOF'
import sqlite3, os, sys
db_path, icons_dir = sys.argv[1], sys.argv[2]
conn = sqlite3.connect(db_path, timeout=30)
rows = conn.execute("SELECT app_id FROM flatpak_apps WHERE icon_local_path = ''").fetchall()
updated = 0
with conn:
    for (app_id,) in rows:
        p = os.path.join(icons_dir, f'{app_id}.png')
        if os.path.isfile(p) and os.path.getsize(p) > 0:
            conn.execute(
                "UPDATE flatpak_apps SET icon_local_path = ? WHERE app_id = ?",
                (p, app_id)
            )
            updated += 1
conn.close()
print(f"  icon_local_path set for {updated} apps.")
PYEOF
else
    log "No system icons found — icons will populate on next catalog update."
fi

log "=== Mirror OS catalog bootstrap complete ==="
